{
  "expo": {
    "name": "Arena Esports",
    "slug": "arena-esports",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A12",
    "splash": {
      "backgroundColor": "#0A0A12",
      "resizeMode": "contain"
    },
    "android": {
      "package": "com.arena.esports",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-notifications",
      "expo-asset",
      "expo-font"
    ]
  }
}
